{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "outDir": "./dist",
    "types": ["node"]
  },
  // src/brandedQr.ts is the Prompt 158 cross-repo branded-QR contract and
  // must stay BYTE-IDENTICAL to the copies in keyhalve-console /
  // validpay-website / checkbooks (sha256
  // ea5d054af32bc4eb6c7014a510adc0fd5cb277052435d1fa6acbf339a9df392d, guarded
  // by tests/brandedQr.test.ts). It indexes arrays/regex matches without
  // guards, so it cannot compile under noUncheckedIndexedAccess — it lives in
  // its own referenced sub-project (tsconfig.contract.json) with ONLY that
  // flag relaxed; imports of ./brandedQr.js resolve to its emitted
  // declarations. Everything else keeps full strictness.
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "src/brandedQr.ts"],
  "references": [{ "path": "./tsconfig.contract.json" }]
}
